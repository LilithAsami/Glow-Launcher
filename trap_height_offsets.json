{
  "_meta": {
    "description": "GLOW Launcher — Trap Height Binary Patching Reference",
    "target": "pakchunk11-WindowsClient.ucas (IoStore, uncompressed regions)",
    "technique": "Find trap GUID as 32-char ASCII in .ucas → patch 2 upper bytes of float32 at GUID_pos - heightOffset",
    "verified": "2026-02-21 against live Fortnite .ucas binary",
    "totalFamilies": 31,
    "totalTraps": 343,
    "verifiedOffsets": 19,
    "zeroDefaultFamilies": 10,
    "problematicFamilies": 2,
    "heightSupportedFamilies": 5
  },

  "howItWorks": {
    "step1": "Search .ucas for 32-char ASCII GUID (e.g. '714D28A34CF939F59429AAB45DDF4796')",
    "step2": "The height is stored as a float32 (IEEE 754, little-endian) at guidPos - heightOffset - 2 to guidPos - heightOffset + 1",
    "step3": "We only patch the UPPER 2 bytes at guidPos - heightOffset (bytes [2] and [3] of the float). Lower 2 bytes stay as-is or zeroed.",
    "step4": "The value in UU (Unreal Units) maps to block height via the heightScale table",
    "note_supported": "Only 5 families actually change height in-game. The other 26 have Blueprint/C++ overrides that ignore the DataTable value.",
    "note_revert": "On first access, the REAL bytes from the file are read and stored as 'original'. Reverts write those exact bytes back."
  },

  "offsetSummary": {
    "_description": "Per-family heightOffset (bytes before GUID where upper 2 height bytes live)",
    "offset_13": ["WallDarts"],
    "offset_14": ["WallLauncher"],
    "offset_15": ["AntiAir", "DefenderPad", "Broadside", "CeilingGasTrap", "CeilingZapper"],
    "offset_17": ["FloorLauncher", "CeilingDropTrap", "CeilingElectricAOE"],
    "offset_18": ["JumpPad"],
    "offset_19": ["WoodenSpikes"],
