    "offset_21": ["FlameGrill", "FloorFreeze", "TarPit", "Campfire", "HealingPad", "HoverboardCurve", "HoverboardSpeed", "LaunchPad", "OBFloorSpikes", "SoundWall", "WallSpikes", "CeilingSpikes", "TarPitCeiling", "JumpPadFree"],
    "offset_23": ["WallLights"],
    "offset_24": ["WallDynamo", "WallWoodSpikes", "Zapomax"]
  },

