{
  "name": "glow-launcher",
  "version": "1.6.0",
  "author": "STWJXSX",
  "description": "GLOW Launcher — Desktop Launcher",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "node scripts/build.js",
    "start": "electron .",
    "dev": "node scripts/build.js && electron .",
    "typecheck": "tsc --noEmit",
    "pack": "node scripts/build.js && electron-builder --dir",
    "dist": "node scripts/build.js && electron-builder"
  },
  "build": {
    "appId": "com.glow.launcher",
    "productName": "GLOW Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/main/locker/output/**"
    ],
    "asarUnpack": [
      "dist/main/locker/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "extraResources": [],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-forge": "^1.3.14",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.19.11",
    "farmhash": "^5.0.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@sapphire/async-queue": "^1.5.5",
    "axios": "^1.6.0",
    "discord.js": "^14.25.1",
    "fnbr": "^4.1.2",
    "koffi": "^2.15.1",
    "node-forge": "^1.3.3",
    "sharp": "^0.34.5",
    "stanza": "^12.21.1"
  }
}
